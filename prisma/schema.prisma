generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Papel global da Pessoa na plataforma. Toda Pessoa é doadora por padrão;
// Administrador e Moderador serão usados a partir da issue 002.
enum GlobalRole {
  DONOR
  MODERATOR
  ADMIN
}

model Person {
  id              String     @id @default(cuid())
  name            String
  email           String     @unique
  passwordHash    String
  role            GlobalRole @default(DONOR)
  termsAcceptedAt DateTime
  isActive        Boolean    @default(true)
  // Validação de Pessoa aprovada autoriza campanhas em nome próprio.
  validatedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  sessions              Session[]
  validationRequests    PersonValidationRequest[]       @relation("ValidationRequester")
  decidedValidations    PersonValidationRequest[]       @relation("ValidationDecider")
  notifications         Notification[]
  auditLogs             AuditLog[]                      @relation("AuditActor")
  organizationMemberships OrganizationMember[]
  submittedOrgValidations OrganizationValidationRequest[] @relation("OrgValidationSubmitter")
  decidedOrgValidations OrganizationValidationRequest[] @relation("OrgValidationDecider")
  ownedCampaigns          Campaign[]                      @relation("CampaignOwnerPerson")
  createdCampaigns        Campaign[]                      @relation("CampaignCreator")
  submittedCampaignChanges CampaignChangeRequest[]        @relation("CampaignChangeSubmitter")
  decidedCampaignChanges  CampaignChangeRequest[]         @relation("CampaignChangeDecider")
  supportOffers           SupportOffer[]                  @relation("SupportOfferDonor")
  decidedSupportOffers    SupportOffer[]                  @relation("SupportOfferDecider")
  authoredPosts           OrganizationPost[]              @relation("PostAuthor")
  postReactions           PostReaction[]                  @relation("PostReactor")
  reports                 Report[]                        @relation("ReportReporter")
  resolvedReports         Report[]                        @relation("ReportResolver")

  @@map("people")
}

enum OrganizationRole {
  REPRESENTATIVE
  MEMBER
}

model Organization {
  id          String    @id @default(cuid())
  name        String
  description String?
  // Contatos públicos exibidos na Página da Organização (opcionais, definidos
  // pelos representantes). Nunca incluem documentos privados de validação.
  publicEmail String?
  phone       String?
  website     String?
  // Imagens públicas do perfil (logo/avatar e capa).
  logoUrl     String?
  coverUrl    String?
  isActive    Boolean   @default(true)
  // Validação de Organização aprovada habilita página pública e campanhas
  // em nome da organização.
  validatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members            OrganizationMember[]
  validationRequests OrganizationValidationRequest[]
  ownedCampaigns     Campaign[]
  posts              OrganizationPost[]

  @@map("organizations")
}

enum CampaignStatus {
  DRAFT
  PENDING_REVIEW
  REJECTED
  PUBLISHED
  CLOSED
  SUSPENDED
}

enum CampaignCategory {
  FOOD
  CLOTHING
  HEALTH
  EDUCATION
  HOUSING
  ANIMALS
  ENVIRONMENT
  OTHER
}

enum SupportType {
  ITEM_DONATION
  VOLUNTEER
  EXTERNAL_FINANCIAL
}

model Campaign {
  id                  String           @id @default(cuid())
  title               String
  description         String
  category            CampaignCategory
  status              CampaignStatus   @default(DRAFT)
  supportTypes        SupportType[]
  // Descrição da necessidade ou meta mensurável da campanha.
  goalDescription     String
  supportInstructions String
  locality            String
  // Pin público do mapa, escolhido manualmente pelo criador. Coordenadas
  // arredondadas (~100 m) para não expor endereço exato por padrão.
  latitude            Float?
  longitude           Float?
  // Ponto logístico privado (endereço exato, horários): nunca aparece em
  // páginas públicas; visível só para envolvidos e moderação.
  logisticsDetails    String?
  // null = campanha explicitamente sem prazo.
  deadline            DateTime?
  // Dono exclusivo: exatamente um entre pessoa validada e organização
  // validada (garantido na camada de aplicação).
  ownerPersonId       String?
  ownerOrganizationId String?
  createdById         String
  // Motivo da última decisão negativa de moderação (rejeição/suspensão),
  // exibido ao dono; limpo ao reenviar para revisão ou publicar.
  statusReason        String?
  // Última movimentação real (criação, edição, apoio confirmado) — base do
  // cálculo de inatividade. updatedAt não serve porque é bumpado por
  // atualizações técnicas, como o próprio aviso de inatividade.
  lastActivityAt      DateTime         @default(now())
  // Última vez que o dono foi avisado de inatividade; evita notificação
  // repetida no mesmo período parado.
  inactivityNotifiedAt DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  ownerPerson       Person?       @relation("CampaignOwnerPerson", fields: [ownerPersonId], references: [id])
  ownerOrganization Organization? @relation(fields: [ownerOrganizationId], references: [id])
  createdBy         Person        @relation("CampaignCreator", fields: [createdById], references: [id])
  changeRequests    CampaignChangeRequest[]
  supportOffers     SupportOffer[]
  reports           Report[]

  @@map("campaigns")
}

enum CampaignChangeStatus {
  PENDING
  APPROVED
  REJECTED
}

// Alteração material proposta para uma campanha publicada. Guarda um
// snapshot dos campos editáveis; a campanha pública só muda quando a
// alteração é aprovada pela moderação.
model CampaignChangeRequest {
  id                  String               @id @default(cuid())
  campaignId          String
  submittedById       String
  status              CampaignChangeStatus @default(PENDING)
  title               String
  description         String
  category            CampaignCategory
  supportTypes        SupportType[]
  goalDescription     String
  supportInstructions String
  locality            String
  latitude            Float
  longitude           Float
  logisticsDetails    String?
  deadline            DateTime?
  decisionReason      String?
  decidedById         String?
  decidedAt           DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  submittedBy Person   @relation("CampaignChangeSubmitter", fields: [submittedById], references: [id])
  decidedBy   Person?  @relation("CampaignChangeDecider", fields: [decidedById], references: [id])

  @@map("campaign_change_requests")
}

enum SupportOfferType {
  ITEM_DONATION
  VOLUNTEER
}

// Ciclo de vida da Oferta de Apoio. Criação e cancelamento pelo Doador são
// da issue 010; confirmação/recusa pela gestão chegam na issue 011.
enum SupportOfferStatus {
  PENDING
  CONFIRMED
  DONOR_CANCELLED
  MANAGER_DECLINED
}

// Oferta de Apoio registrada por um Doador numa campanha publicada. Não passa
// por moderação para ficar visível à gestão da campanha; os detalhes (contato,
// item, disponibilidade) nunca aparecem em páginas públicas.
model SupportOffer {
  id                String             @id @default(cuid())
  campaignId        String
  donorId           String
  type              SupportOfferType
  status            SupportOfferStatus @default(PENDING)
  // Anonimato público: oculta o Doador nas páginas públicas, mas o vínculo
  // interno com o Doador permanece rastreável.
  publiclyAnonymous Boolean            @default(false)
  // Contato para coordenação (telefone, e-mail), visível só à gestão.
  contact           String
  // Doação de item: detalhes do item ofertado.
  itemName          String?
  itemQuantity      String?
  itemCondition     String?
  coordinationPreference String?
  // Voluntariado: detalhes da disponibilidade.
  availability      String?
  helpType          String?
  // Observação livre do Doador.
  note              String?
  // Decisão da gestão (issue 011): motivo da recusa e quem/quando decidiu.
  declineReason     String?
  decidedById       String?
  decidedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donor     Person   @relation("SupportOfferDonor", fields: [donorId], references: [id], onDelete: Cascade)
  decidedBy Person?  @relation("SupportOfferDecider", fields: [decidedById], references: [id])
  reports   Report[]

  @@map("support_offers")
}

model OrganizationMember {
  id             String           @id @default(cuid())
  organizationId String
  personId       String
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  person       Person       @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([organizationId, personId])
  @@map("organization_members")
}

model OrganizationValidationRequest {
  id                String           @id @default(cuid())
  organizationId    String
  submittedById     String
  status            ValidationStatus @default(PENDING)
  note              String?
  documentConsentAt DateTime
  decisionReason    String?
  decidedById       String?
  decidedAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  organization Organization                     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  submittedBy  Person                           @relation("OrgValidationSubmitter", fields: [submittedById], references: [id])
  decidedBy    Person?                          @relation("OrgValidationDecider", fields: [decidedById], references: [id])
  documents    OrganizationValidationDocument[]

  @@map("organization_validation_requests")
}

model OrganizationValidationDocument {
  id         String   @id @default(cuid())
  requestId  String
  fileName   String
  storedName String   @unique
  mimeType   String
  sizeBytes  Int
  createdAt  DateTime @default(now())

  request OrganizationValidationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("organization_validation_documents")
}

enum OrganizationPostStatus {
  PUBLISHED
  HIDDEN
  SUSPENDED
}

// Post de Organização: atualização (texto, imagens, link de vídeo externo)
// publicada na Página da Organização. Pode ser ocultado pelo representante ou
// suspenso pela moderação.
model OrganizationPost {
  id             String                 @id @default(cuid())
  organizationId String
  authorId       String
  status         OrganizationPostStatus @default(PUBLISHED)
  content        String
  imageUrls      String[]
  // Link externo de vídeo (YouTube etc.); upload de vídeo está fora do MVP.
  videoUrl       String?
  // Motivo da suspensão pela moderação.
  statusReason   String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author       Person         @relation("PostAuthor", fields: [authorId], references: [id])
  reactions    PostReaction[]
  reports      Report[]

  @@map("organization_posts")
}

// Reação leve de um Doador a um Post; no máximo uma por post por doador. As
// páginas públicas mostram apenas a contagem agregada, nunca a lista.
model PostReaction {
  id        String   @id @default(cuid())
  postId    String
  donorId   String
  createdAt DateTime @default(now())

  post  OrganizationPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  donor Person           @relation("PostReactor", fields: [donorId], references: [id], onDelete: Cascade)

  @@unique([postId, donorId])
  @@map("post_reactions")
}

enum ReportTargetType {
  CAMPAIGN
  ORGANIZATION_POST
  SUPPORT_OFFER
}

enum ReportStatus {
  OPEN
  RESOLVED
}

enum ReportResolution {
  DISMISSED
  UPHELD
}

// Denúncia de conteúdo abusivo. Sempre vinculada a um objeto concreto:
// exatamente um entre campaignId, organizationPostId e supportOfferId é
// preenchido, conforme targetType (garantido na camada de aplicação).
model Report {
  id                 String            @id @default(cuid())
  reporterId         String
  targetType         ReportTargetType
  campaignId         String?
  organizationPostId String?
  supportOfferId     String?
  reason             String
  status             ReportStatus      @default(OPEN)
  resolution         ReportResolution?
  resolutionNote     String?
  resolvedById       String?
  resolvedAt         DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  reporter         Person            @relation("ReportReporter", fields: [reporterId], references: [id])
  resolvedBy       Person?           @relation("ReportResolver", fields: [resolvedById], references: [id])
  campaign         Campaign?         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  organizationPost OrganizationPost? @relation(fields: [organizationPostId], references: [id], onDelete: Cascade)
  supportOffer     SupportOffer?     @relation(fields: [supportOfferId], references: [id], onDelete: Cascade)

  @@map("reports")
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  personId  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

enum ValidationStatus {
  PENDING
  APPROVED
  REJECTED
  REVOKED
}

model PersonValidationRequest {
  id                String           @id @default(cuid())
  personId          String
  status            ValidationStatus @default(PENDING)
  // Mensagem opcional de quem solicita (contexto, correções após rejeição).
  note              String?
  // Consentimento específico para envio de documentos é obrigatório.
  documentConsentAt DateTime
  decisionReason    String?
  decidedById       String?
  decidedAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  person    Person               @relation("ValidationRequester", fields: [personId], references: [id], onDelete: Cascade)
  decidedBy Person?              @relation("ValidationDecider", fields: [decidedById], references: [id])
  documents ValidationDocument[]

  @@map("person_validation_requests")
}

model ValidationDocument {
  id         String   @id @default(cuid())
  requestId  String
  // Nome original mostrado na interface; storedName é o nome aleatório no
  // armazenamento privado (fora de public/).
  fileName   String
  storedName String   @unique
  mimeType   String
  sizeBytes  Int
  createdAt  DateTime @default(now())

  request PersonValidationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("validation_documents")
}

model Notification {
  id        String    @id @default(cuid())
  personId  String
  title     String
  body      String
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  targetType String
  targetId   String
  reason     String?
  createdAt  DateTime @default(now())

  actor Person? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}
